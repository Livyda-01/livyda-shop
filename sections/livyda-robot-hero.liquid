<script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.82/build/spline-viewer.js"></script>

<section class="lv-robot-hero" id="livyda-robot-hero">

  <!-- Robot 3D Scene (rechts) -->
  <div class="lv-robot-hero__spline">
    <spline-viewer
      url="{{ section.settings.spline_url | default: 'https://prod.spline.design/PyzDhpQ9E5f1E3MT/scene.splinecode' }}"
      style="width:100%;height:100%;--spline-viewer-logo-display:none;"
    ></spline-viewer>
    <!-- Watermark entfernen -->
    <div class="lv-robot-hero__spline-cover"></div>
  </div>

  <!-- Text (links) -->
  <div class="lv-robot-hero__content">
    <span class="lv-robot-hero__eyebrow">{{ section.settings.eyebrow | default: 'Next Generation' }}</span>
    <h1 class="lv-robot-hero__title">{{ section.settings.title | default: 'Precision<br>Redefined' }}</h1>
    <p class="lv-robot-hero__text">{{ section.settings.subtitle | default: 'High-performance cleaning.<br>Minimal design. Modern living.' }}</p>
    <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="lv-robot-hero__cta">
      {{ section.settings.button_label | default: 'Discover' }}
    </a>
  </div>

</section>

{% schema %}
{
  "name": "Livyda Robot Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Next Generation"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Precision<br>Redefined"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "High-performance cleaning. Minimal design. Modern living."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Discover"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "spline_url",
      "label": "Spline Scene URL",
      "default": "https://prod.spline.design/PyzDhpQ9E5f1E3MT/scene.splinecode"
    }
  ],
  "presets": [
    {
      "name": "Livyda Robot Hero"
    }
  ]
}
{% endschema %}
