<section class="lv-products">
  <div class="lv-products__hd lv-in">
    {%- if section.settings.label != blank -%}
      <span class="lv-products__label">{{ section.settings.label }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="lv-products__title">{{ section.settings.title }}</h2>
    {%- endif -%}
  </div>

  <div class="lv-grid lv-stagger">
    {%- for block in section.blocks -%}
      {%- assign prod = block.settings.product -%}
      {%- if prod != blank -%}
        <a href="{{ prod.url }}" class="lv-card" {{ block.shopify_attributes }}>
          <div class="lv-card__img-wrap">
            {%- if prod.featured_image != blank -%}
              <img
                class="lv-card__img"
                src="{{ prod.featured_image | image_url: width: 600 }}"
                srcset="
                  {{ prod.featured_image | image_url: width: 400 }} 400w,
                  {{ prod.featured_image | image_url: width: 600 }} 600w,
                  {{ prod.featured_image | image_url: width: 900 }} 900w
                "
                sizes="(max-width: 749px) 100vw, 33vw"
                alt="{{ prod.featured_image.alt | escape | default: prod.title }}"
                loading="lazy"
                width="{{ prod.featured_image.width }}"
                height="{{ prod.featured_image.height }}"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'lv-card__img' }}
            {%- endif -%}
            {%- if block.settings.badge != blank -%}
              <span class="lv-card__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
          </div>
          <div class="lv-card__info">
            <p class="lv-card__name">{{ prod.title }}</p>
            {%- if prod.description != blank -%}
              <p class="lv-card__desc">{{ prod.description | strip_html | truncate: 90 }}</p>
            {%- endif -%}
            <p class="lv-card__price">
              {%- if prod.compare_at_price > prod.price -%}
                <span class="lv-card__compare">{{ prod.compare_at_price | money }}</span>
              {%- endif -%}
              {{ prod.price | money }}
            </p>
          </div>
        </a>
      {%- else -%}
        <div class="lv-card" {{ block.shopify_attributes }}>
          <div class="lv-card__img-wrap">
            {{ 'product-1' | placeholder_svg_tag: 'lv-card__img' }}
            {%- if block.settings.badge != blank -%}
              <span class="lv-card__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
          </div>
          <div class="lv-card__info">
            <p class="lv-card__name">{{ block.settings.name | default: 'Select a product' }}</p>
            <p class="lv-card__price">—</p>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Livyda Products",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Our Selection" },
    { "type": "text", "id": "title", "label": "Title", "default": "Curated Essentials" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "badge", "label": "Badge", "placeholder": "New" },
        { "type": "text", "id": "name", "label": "Fallback name" }
      ]
    }
  ],
  "presets": [{
    "name": "Livyda Products",
    "blocks": [
      { "type": "product" },
      { "type": "product" },
      { "type": "product" }
    ]
  }]
}
{% endschema %}
