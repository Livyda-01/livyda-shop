<div class="lv-ap">
  <div class="lv-ap__hero">
    {%- if section.settings.image != blank -%}
      <img
        class="lv-ap__hero-img"
        src="{{ section.settings.image | image_url: width: 1600 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="eager"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <div class="lv-ap__hero-img" style="background:linear-gradient(160deg,#E9E5E0,#C8C3BB);"></div>
    {%- endif -%}
    <div class="lv-ap__hero-overlay"></div>
    <div class="lv-ap__hero-text">
      <span class="lv-ap__hero-label">{{ section.settings.hero_label | default: 'About Us' }}</span>
      <h1 class="lv-ap__hero-title">{{ section.settings.hero_title | default: 'We believe in quiet excellence' }}</h1>
    </div>
  </div>

  <div class="lv-ap__intro lv-in">
    <p class="lv-ap__intro-text">{{ section.settings.intro | default: 'We curate high-performance cleaning solutions for the modern home — designed with purpose, built for precision.' }}</p>
  </div>

  <div class="lv-ap__values lv-stagger">
    {%- for block in section.blocks -%}
      {%- if block.type == 'value' -%}
        <div class="lv-ap__val" {{ block.shopify_attributes }}>
          <span class="lv-ap__val-num">0{{ forloop.index }}</span>
          <h3 class="lv-ap__val-title">{{ block.settings.title }}</h3>
          <p class="lv-ap__val-text">{{ block.settings.text }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="lv-ap__mission lv-in">
    <span class="lv-ap__mission-label">{{ section.settings.mission_label | default: 'Our Mission' }}</span>
    <blockquote class="lv-ap__mission-quote">{{ section.settings.mission_quote | default: '"Minimal design. Maximum performance."' }}</blockquote>
  </div>

  <div class="lv-ap__cta lv-in">
    <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="lv-ap__cta-btn">
      {{ section.settings.cta_label | default: 'Shop Now' }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Livyda About Page",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero Image" },
    { "type": "text", "id": "hero_label", "label": "Hero Label", "default": "About Us" },
    { "type": "text", "id": "hero_title", "label": "Hero Title", "default": "We believe in quiet excellence" },
    { "type": "textarea", "id": "intro", "label": "Intro Text" },
    { "type": "text", "id": "mission_label", "label": "Mission Label", "default": "Our Mission" },
    { "type": "textarea", "id": "mission_quote", "label": "Mission Quote", "default": "\"Minimal design. Maximum performance.\"" },
    { "type": "text", "id": "cta_label", "label": "CTA Label", "default": "Shop Now" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "value", "name": "Value",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Quality" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Exceptional build quality for lasting performance." }
      ]
    }
  ],
  "presets": [{
    "name": "Livyda About Page",
    "blocks": [
      { "type": "value", "settings": { "title": "Quality", "text": "Every product is selected for exceptional build quality and lasting performance." } },
      { "type": "value", "settings": { "title": "Design", "text": "We believe that functional objects should also be beautiful objects." } },
      { "type": "value", "settings": { "title": "Service", "text": "From first click to delivery — a seamless, premium experience." } }
    ]
  }]
}
{% endschema %}
